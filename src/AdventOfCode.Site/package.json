{
  "name": "adventofcode",
  "private": true,
  "type": "module",
  "version": "10.0.0",
  "description": "Solutions for Advent of Code in C# and TypeScript",
  "scripts": {
    "build": "webpack",
    "format": "prettier --write scripts/**/*.ts",
    "format-check": "prettier --check scripts/**/*.ts",
    "lint": "eslint scripts",
    "lint:fix": "eslint scripts --fix",
    "test": "vitest run",
    "watch": "webpack --watch",
    "publish": "npm run build && npm run format && npm run lint",
    "all": "npm run publish && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/martincostello/adventofcode.git"
  },
  "author": "martincostello",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/eslint-plugin": "1.6.15",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "linq-to-typescript": "10.0.0",
    "prettier": "3.8.2",
    "ts-loader": "9.5.7",
    "ts-md5": "2.0.1",
    "tsify": "5.0.4",
    "typescript": "6.0.2",
    "vitest": "4.1.3",
    "webpack": "5.106.0",
    "webpack-cli": "7.0.2"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "endOfLine": "auto",
    "printWidth": 140,
    "quoteProps": "consistent",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "es5",
    "useTabs": false
  }
}
